{
  "name": "basquio",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --filter @basquio/web dev",
    "build": "pnpm --filter @basquio/web build",
    "lint": "pnpm --filter @basquio/web lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "qa": "pnpm qa:basquio",
    "qa:basquio": "tsx scripts/qa-context.ts",
    "demo:generate": "tsx scripts/run-demo-generation.ts",
    "inngest:check": "tsx scripts/check-inngest.ts",
    "workflow:dev": "pnpm --filter @basquio/workflows workflow:dev",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset --local",
    "supabase:lint": "supabase db lint --local"
  },
  "dependencies": {
    "@types/pdf-parse": "^1.1.5",
    "csv-parse": "^6.1.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "pdf-parse": "^1.1.4",
    "pptxgenjs": "^3.12.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.5.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "sharp",
      "@img/sharp-linux-x64",
      "@img/sharp-libvips-linux-x64"
    ]
  }
}
