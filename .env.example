# Memory v1 schema gate; defaults false until Briefs 2-6 ship behavioural changes.
# Brief 1 lands the storage layer (workspace_rule, brand_guideline,
# anticipation_hints, memory_workflows, memory_workflow_runs, memory_audit) plus
# member-scoped RLS and the audit trigger. No app code reads from these tables
# while this flag is false. See docs/research/2026-04-25-sota-implementation-specs.md.
MEMORY_V2_ENABLED=false

# Chat router v2 gate (Memory v1 Brief 2). When true, the chat agent runs the
# new path: 4-tier prompt cache (1h static system + 5m workspace brand pack +
# 5m scope context pack + live), Haiku intent classifier on step 0, intent-gated
# typed tools (queryStructuredMetric, queryBrandRule, queryEntityFact,
# searchEvidence) plus the existing write/UI tools, and per-turn aggregate
# telemetry to chat_tool_telemetry. When false (default), the chat surface keeps
# the pre-Brief-2 streamText + retrieveContextTool path. See
# docs/research/2026-04-25-sota-implementation-specs.md §5, §6.
CHAT_ROUTER_V2_ENABLED=false

# Brand-guideline extraction gate (Memory v1 Brief 3). When true, every
# knowledge_documents row uploaded with kind='brand_book' triggers the BAML
# extraction pipeline (Sonnet 4.6 extract + Haiku 4.5 validate, persist via
# SECURITY DEFINER RPC) after file ingest completes inside the Railway
# worker. When false (default), brand-book uploads chunk and embed only,
# and queryBrandRuleTool keeps returning empty for brand_guideline. The
# regular passage-memory path is unaffected by this flag in either state.
# Per-PDF cost ~$3-5 on a 100-300 page brand book. See
# docs/research/2026-04-25-sota-implementation-specs.md §4.
BRAND_EXTRACTION_ENABLED=false

# Chat-turn fact extractor gate (Memory v1 Brief 4). Default false runs
# DRY MODE: every chat turn is mined for facts/rules/preferences/aliases/
# entities by Haiku 4.5 (Mem0 V3 ADD-only), confidence-gated:
#   < 0.6 dropped, 0.6..0.8 inserted as pending, > 0.8 ALSO inserted as
# pending in dry mode. When set to true, high-confidence extractions
# auto-promote to durable memory (facts/workspace_rule/memory_entries/
# entities) via auto_promote_high_confidence RPC. The dry-mode
# observation period (24-48 hours of real chat traffic) is the load-
# bearing gate before flipping. Per-turn cost ~$0.002 on Haiku 4.5.
# See docs/research/2026-04-25-sota-implementation-specs.md §7.
CHAT_EXTRACTOR_ENABLED=false

