{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@basquio/core": ["packages/core/src/index.ts"],
      "@basquio/data-ingest": ["packages/data-ingest/src/index.ts"],
      "@basquio/intelligence": ["packages/intelligence/src/index.ts"],
      "@basquio/render-charts": ["packages/render-charts/src/index.ts"],
      "@basquio/render-pdf": ["packages/render-pdf/src/index.ts"],
      "@basquio/render-pptx": ["packages/render-pptx/src/index.ts"],
      "@basquio/research": ["packages/research/src/index.ts"],
      "@basquio/research/firecrawl": ["packages/research/src/firecrawl-client.ts"],
      "@basquio/research/fiber": ["packages/research/src/fiber-client.ts"],
      "@basquio/research/http": ["packages/research/src/http.ts"],
      "@basquio/template-engine": ["packages/template-engine/src/index.ts"],
      "@basquio/types": ["packages/types/src/index.ts"],
      "@basquio/workflows": ["packages/workflows/src/index.ts"],
      "@basquio/bot": ["apps/bot/src/index.ts"]
    }
  }
}
