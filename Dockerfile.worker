FROM node:22-bookworm-slim

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable \
  && apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-pip make g++ \
  && python3 -m pip install --break-system-packages --no-cache-dir openpyxl==3.1.5 \
  && python3 -c "import openpyxl" \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

RUN pnpm install --frozen-lockfile \
  && pnpm run build

CMD ["node", "--import", "tsx", "scripts/worker.ts"]
