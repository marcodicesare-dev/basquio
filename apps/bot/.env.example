# Discord
DISCORD_BOT_TOKEN=           # Bot token from Discord Developer Portal
DISCORD_GUILD_ID=            # Your server ID
DISCORD_VOICE_CHANNEL_ID=    # "The Office" voice channel ID
DISCORD_BOT_CHANNEL_ID=      # #basquio-ai text channel ID
DISCORD_GENERAL_CHANNEL_ID=  # #general text channel ID

# Deepgram
DEEPGRAM_API_KEY=            # From deepgram.com

# Anthropic (Claude)
ANTHROPIC_API_KEY=           # For extraction

# Linear
LINEAR_API_KEY=              # From linear.app/settings/api
LINEAR_TEAM_ID=              # Basquio team ID

# Supabase (reuse from existing Basquio config)
SUPABASE_URL=                # Your project URL
SUPABASE_SERVICE_ROLE_KEY=   # Service role key (NOT anon key)

# Optional
WHISPER_API_KEY=             # OpenAI key for Whisper fallback
NODE_ENV=production
